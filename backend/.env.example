MONGODB_CONNECTIONSTRING=mongodb+srv://<user>:<pass>@<cluster>/<db>
PORT=5001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=please_set_a_long_random_string
JWT_EXPIRES_IN=7d

# Đăng nhập Google — Client ID (OAuth 2.0 Web) từ Google Cloud Console
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
# Frontend: frontend/.env cùng giá trị trong VITE_GOOGLE_CLIENT_ID

# Email OTP (optional in development; required in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=TodoX <your_email@gmail.com>

# AI Chat (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Thanh toán mở khóa Chat (Stripe) — https://dashboard.stripe.com/apikeys

# URL frontend (redirect sau Checkout), ví dụ http://localhost:5173 hoặc https://domain.com
FRONTEND_URL=http://localhost:5173
CHAT_PRICE_VND=49000
CHAT_PRODUCT_NAME=Mở khóa Chat AI — TodoX
# Dev: bỏ qua paywall chat khi chưa có Stripe (không dùng production)
# DISABLE_CHAT_PAYWALL=true
